---
const criticalStyle = String.raw`<style>
  :root {
    /* Homepage palette mapped onto the landing page tokens. */
    --background0: #282a36;
    --background1: #2d2f3d;
    --background2: #383a4d;
    --background3: #424559;
    --foreground0: #d7dae8;
    --foreground1: #a8aabc;
    --foreground2: #ffeecb;
    --font-size: 16px;
    --line-height: 1.5;
    --font-family: monospace;
  }

  html,
  body {
    min-height: 100%;
    background-color: #282a36;
    color: var(--foreground0);
    font-family: var(--font-family);
    font-size: var(--font-size);
    font-weight: 400;
    line-height: var(--line-height);
    font-variant-ligatures: common-ligatures;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    outline: none;
  }

  body {
    position: relative;
    overflow-x: hidden;
  }

  a {
    color: var(--foreground2);
    text-decoration: underline;
  }

  a:hover {
    opacity: 0.8;
  }

  /* Background animation container. Keep these styles unchanged in behavior. */
  .grid-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: grid;
    background-color: #282a36;
    gap: 1px;
    z-index: 0;
  }

  .cell {
    width: 100%;
    height: 100%;
    background: #2d2f3d;
    transition:
      transform 0.2s ease-out,
      background-color 0.2s ease-out;
  }

  .cell.alive {
    background: #383a4d;
    transform: scale(0.95);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(0.95);
    }

    50% {
      transform: scale(1);
      background: #424559;
    }

    100% {
      transform: scale(0.95);
      background: #383a4d;
    }
  }

  /* Foreground layout for the homepage revamp. */
  .home-shell {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    width: min(100%, 112ch);
    margin: 0 auto;
    padding: 2.5lh 4ch 3lh;
  }

  .home-main {
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    padding-top: 7lh;
  }

  .home-copy {
    width: min(100%, 54ch);
    margin-left: 6ch;
  }

  .home-logo {
    display: block;
    width: 16ch;
    max-width: 100%;
    margin: 0 auto 2lh;
  }

  .home-copy p {
    color: var(--foreground0);
    text-wrap: pretty;
  }

  .home-copy p + p {
    margin-top: 1.5lh;
  }

  @media (max-width: 900px) {
    .home-shell {
      width: 100%;
      padding: 2lh 3ch 3lh;
    }

    .home-main {
      padding-top: 5lh;
    }

    .home-copy {
      margin-left: 3ch;
    }
  }

  @media (max-width: 640px) {
    .home-shell {
      padding: 2lh 2ch 3lh;
    }

    .home-logo {
      width: 14ch;
      margin-bottom: 1.5lh;
    }

    .home-main {
      padding-top: 3lh;
    }

    .home-copy {
      margin-left: 0;
      width: 100%;
    }
  }
</style>`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cottongeeks LLC</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Cottongeeks Blog" href="/rss.xml" />
    <Fragment set:html={criticalStyle} />
    <script>
      import { GameOfLife } from '../game.ts'
      new GameOfLife('grid')
    </script>
  </head>
  <body>
    <div id="grid" class="grid-container" aria-hidden="true"></div>

    <div class="home-shell">
      <main class="home-main">
        <div class="home-copy">
          <img src="/cottongeeks.svg" alt="Cottongeeks LLC" class="home-logo" />
          <p>
            Cottongeeks is a solo-powered boutique consultancy led by
            <a href="https://www.linkedin.com/in/debugjois">Deepak Jois</a>, a software engineer
            with over 20 years of industry experience. We partner with startup founders and
            early-stage tech businesses to transform their ideas into production-ready solutions.
          </p>
          <p>
            Check out some <a href="/articles">articles</a>, or email us at
            <a href="mailto:hi@cottongeeks.com">hi@cottongeeks.com</a>
          </p>
        </div>
      </main>
    </div>
  </body>
</html>
